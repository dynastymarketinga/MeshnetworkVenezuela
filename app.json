{
  "expo": {
    "name": "MeshnetworkVenezuela",
    "slug": "meshnetwork-venezuela",
    "version": "1.1.0",
    "orientation": "portrait",
    "icon": "./assets/logo.jpg",
    "userInterfaceStyle": "dark",
    "scheme": "meshnetworkvenezuela",
    "splash": {
      "image": "./assets/logo.jpg",
      "resizeMode": "contain",
      "backgroundColor": "#F5F0E8"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.vicarx.meshnetworkvenezuela",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "MeshnetworkVenezuela usa GPS para registrar y navegar a puntos exactos de rescate en La Guaira.",
        "LSApplicationQueriesSchemes": [
          "maps",
          "comgooglemaps",
          "google.navigation"
        ]
      }
    },
    "android": {
      "package": "com.vic_arx.meshnetworkvenezuela",
      "adaptiveIcon": {
        "foregroundImage": "./assets/logo.jpg",
        "backgroundColor": "#F5F0E8"
      },
      "permissions": [
        "ACCESS_COARSE_LOCATION",
        "ACCESS_FINE_LOCATION",
        "SEND_SMS",
        "RECEIVE_SMS",
        "INTERNET",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION"
      ],
      "intentFilters": [
        {
          "action": "VIEW",
          "data": [
            {
              "scheme": "geo"
            }
          ],
          "category": [
            "DEFAULT",
            "BROWSABLE"
          ]
        }
      ]
    },
    "web": {
      "favicon": "./assets/logo.jpg"
    },
    "plugins": [
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "MeshnetworkVenezuela usa GPS para registrar y navegar a puntos exactos de rescate en La Guaira."
        }
      ],
      "expo-sqlite"
    ],
    "extra": {
      "eas": {
        "projectId": "f12c6744-8204-41d8-aa78-f47f35e6c5be"
      }
    },
    "owner": "victorx2"
  }
}
